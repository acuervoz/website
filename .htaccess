RewriteEngine On

# Prefer PHP index files over static HTML for directory requests
DirectoryIndex index.php index.html

# organizer/ is a self-contained app that's called via direct .php URLs with
# query strings / POST bodies (e.g. api.php?action=...) — none of the
# clean-URL rewriting below applies to it, or it'll mangle those requests.
RewriteRule ^organizer/ - [L]

# admin/ (stories CMS) is the same kind of self-contained app — same reasoning.
RewriteRule ^admin/ - [L]

# Spanish mirror: /es and /es/<path> serve the exact same files as <path>.
# PHP (see partials/content.php) detects the /es prefix from REQUEST_URI,
# which always reflects the original URL regardless of this internal rewrite.
RewriteRule ^es/?$ index.php [L]

# /es/<dir> (no trailing slash) needs its own redirect that keeps the /es
# prefix — otherwise the generic strip-prefix rule below runs first, and
# Apache's automatic trailing-slash redirect for the (now-stripped) directory
# request would silently bounce the visitor back to the English URL.
RewriteCond %{DOCUMENT_ROOT}/$1 -d
RewriteRule ^es/(.+[^/])$ /es/$1/ [R=301,L]

RewriteRule ^es/(.+)$ $1 [L]

# Redirect .html / .php URLs to clean URLs (301)
RewriteCond %{THE_REQUEST} \s/(.+)\.(html|php)[\s?] [NC]
RewriteRule ^ /%1 [R=301,L]

# Legacy flat story URLs -> new per-project nested structure
# (projects themselves need no rule here: /projects/<slug> still resolves
# straight to /projects/<slug>/index.html now that <slug> is a directory)
RewriteRule ^projects/the-night-of-the-milipede/?$        /projects/unclassified/the-night-of-the-milipede/        [R=301,L]
RewriteRule ^projects/hells-janitor/?$                     /projects/unclassified/hells-janitor/                     [R=301,L]
RewriteRule ^projects/do-it-monday/?$                       /projects/mirror-self/do-it-monday/                       [R=301,L]
RewriteRule ^projects/a-deeply-rooted-curse/?$              /projects/pananormales/a-deeply-rooted-curse/             [R=301,L]
RewriteRule ^projects/the-bodies-inside-the-laguna-negra/?$ /projects/pananormales/the-bodies-inside-the-laguna-negra/ [R=301,L]
RewriteRule ^projects/the-machine-gods-manifesto/?$         /projects/futuristic-historical/the-machine-gods-manifesto/ [R=301,L]

# Internally serve the .php file for clean URLs, else fall back to .html
# (checked before !-d so /projects still maps to projects.html
# even though a projects/ directory also exists for sub-pages)
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)$ $1.php [L]

RewriteCond %{REQUEST_FILENAME}.html -f
RewriteCond %{REQUEST_FILENAME} !-f
RewriteRule ^(.+)$ $1.html [L]
